# Copy this file to .env and fill in values. Do not commit .env.
# Required for the app (development and production)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required in production (NODE_ENV=production). Optional in dev (dev default used).
JWT_SECRET=your-long-random-secret-at-least-32-chars
SESSION_SECRET=another-long-random-secret

# Required in production if you use admin PIN login. Optional in dev (default 1234567).
ADMIN_PIN=your-admin-pin

# Only needed when running: npm run db:create-admins
# Set these (in .env or inline) so the script can create/update admin users without storing passwords in code.
# ADMIN_PASSWORD_1=password-for-first-admin-user
# ADMIN_PASSWORD_2=password-for-second-admin-user

# Public site URL (no trailing slash). Used for password reset links, verification welcome email sign-in link, etc.
# APP_URL=https://your-domain.com

# Optional (used by specific features)
# SENDER_EMAIL=noreply@nursingrocks.com     # Email address for "From:" header on verification/ticket emails
# SUPPORT_EMAIL=support@nursingrocks.com    # Email address shown for user support replies and questions
# VERIFICATION_API_KEY=
# STRIPE_SECRET_KEY=
# CUSTOMCAT_API_KEY=
# RESEND_API_KEY=
# CRON_SECRET=           # Secret for securing /api/cron/* endpoints. Set this in Vercel env vars too.
# VIDEO_B2_ACCESS_KEY_ID=
# VIDEO_B2_SECRET_ACCESS_KEY=
# VIDEO_B2_BUCKET=
# VIDEO_B2_S3_ENDPOINT=
# VIDEO_B2_REGION=
# VIDEO_CDN_BASE_URL=
# VIDEO_SOURCE_PREFIX=
# VIDEO_HLS_PREFIX=
# VIDEO_POSTER_PREFIX=
# ALLOWED_ORIGINS=
